# Skyrent backend env vars — copy to .env and fill in

# Auth (required)
APP_USERNAME=admin
APP_PASSWORD=
JWT_SECRET=

# Database
# DB_PATH=./db/portfolio.db          # Railway: /data/portfolio.db

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=info@skycapital.pro

# Frontend URL — used for Stripe success/cancel redirects + tenant portal welcome emails
FRONTEND_URL=http://localhost:5173
# TENANT_PORTAL_URL=                 # falls back to FRONTEND_URL if unset

# Stripe (test or live — Dashboard → Developers → API keys)
STRIPE_PUBLISHABLE_KEY=pk_test_or_live_...
STRIPE_SECRET_KEY=sk_test_or_live_...
# Get via Dashboard → Developers → Webhooks → endpoint → Signing secret
# Or for local dev: stripe listen --forward-to localhost:3002/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Trading 212 (Public Beta API) — двойка ID + Secret (HTTP Basic auth)
# Settings → API (Beta) → Generate API key
# Scopes (read-only достатъчно): Account info, Portfolio, Orders, History
T212_API_KEY_ID=
T212_API_KEY=
# T212_BASE_URL=https://demo.trading212.com/api/v0   # за Practice (demo) акаунт

# Metal spot prices — primary: goldapi.io, fallback: metalpriceapi.com
# Регистрирай се на двете за 100 + 100 req/месец безплатно
GOLD_API_KEY=
METAL_PRICE_API_KEY=
